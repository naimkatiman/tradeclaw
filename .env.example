# === TradeClaw Configuration ===

# App
APP_PORT=3000
APP_URL=http://localhost:3000

# Database
DB_NAME=tradeclaw
DB_USER=tradeclaw
DB_PASSWORD=changeme  # ⚠️ CHANGE THIS IN PRODUCTION

# Auth
AUTH_SECRET=  # Generate with: openssl rand -hex 32

# Scanner
SCAN_INTERVAL=60           # Seconds between scans
SCAN_INSTRUMENTS=all       # Options: all, forex, crypto, metals
SCAN_MAX_CONCURRENT=50     # Max concurrent instrument scans

# Data Sources (add your API keys)
ALPHA_VANTAGE_KEY=
POLYGON_KEY=
BINANCE_KEY=
BINANCE_SECRET=

# Telegram Bot (optional — for signal alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: Logging
LOG_LEVEL=info  # debug | info | warn | error
