# TradeClaw Configuration — copy this to .env and customize
DB_NAME=tradeclaw
DB_USER=tradeclaw
DB_PASSWORD=changeme_in_production
APP_PORT=3000
APP_URL=http://localhost:3000
AUTH_SECRET=generate-with-openssl-rand-hex-32
REDIS_URL=redis://redis:6379
SCAN_INTERVAL=60
SCAN_INSTRUMENTS=all
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/telegram/webhook
# Legacy single-chat alerting (deprecated — use /subscribe bot commands instead)
TELEGRAM_CHAT_ID=optional_for_alerts
# Private group IDs for paid tiers (optional)
TELEGRAM_PRO_GROUP_ID=optional_pro_group_chat_id
TELEGRAM_ELITE_GROUP_ID=optional_elite_group_chat_id
