# TradeClaw Configuration — copy this to .env and customize
# ⚠️  Variables marked REQUIRED must be set before `docker compose up`

# ---------------------------------------------------------------------------
# Database (REQUIRED)
# ---------------------------------------------------------------------------
DB_NAME=tradeclaw
DB_USER=tradeclaw
DB_PASSWORD=                          # REQUIRED — generate with: openssl rand -hex 16

# ---------------------------------------------------------------------------
# App (REQUIRED)
# ---------------------------------------------------------------------------
APP_PORT=3000
APP_URL=http://localhost:3000         # Set to your public URL in production
AUTH_SECRET=                          # REQUIRED — generate with: openssl rand -hex 32
                                      # Passed as AUTH_SECRET to the app container (see docker-compose.yml)

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# ---------------------------------------------------------------------------
# Scanner
# ---------------------------------------------------------------------------
SCAN_INTERVAL=60
SCAN_INSTRUMENTS=all

# ---------------------------------------------------------------------------
# Telegram (optional — for bot alerts)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
# Channel / group IDs (use negative numbers for groups)
TELEGRAM_FREE_CHANNEL_ID=
TELEGRAM_PRO_GROUP_ID=
TELEGRAM_ELITE_GROUP_ID=

# ---------------------------------------------------------------------------
# Discord (optional — for Discord bot signals)
# ---------------------------------------------------------------------------
DISCORD_BOT_TOKEN=                    # Bot token from https://discord.com/developers
DISCORD_CLIENT_ID=                    # Application ID (for invite link)

# ---------------------------------------------------------------------------
# Stripe (optional — for paid tiers)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_ELITE_MONTHLY_PRICE_ID=
STRIPE_ELITE_ANNUAL_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_ELITE_MONTHLY_PRICE_ID=

# ---------------------------------------------------------------------------
# Upstash Redis (optional — for API rate limiting on Elite tier)
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------------------------------------
# Cron / GitHub Action (used by .github/workflows/signal-log.yml)
# ---------------------------------------------------------------------------
CRON_SECRET=                          # Shared secret for the /api/cron/signals endpoint
                                      # Set as a GitHub Actions secret (CRON_SECRET) and
                                      # in your deployed app's environment variables
                                      # Generate with: openssl rand -hex 32

# ---------------------------------------------------------------------------
# Supabase (optional — Postgres-backed storage instead of JSON files)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
