# TradeClaw — Environment Variables
# Copy this file to .env.local and fill in your values.

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=https://tradeclaw.win

# Admin secret for protecting sensitive API endpoints (plugins, keys, import, webhooks)
# Generate with: openssl rand -hex 32
ADMIN_SECRET=

# Set to "true" to show the demo banner and enable feature hints for first-time visitors
NEXT_PUBLIC_DEMO_MODE=false

# ---------------------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — create these in your Stripe Dashboard
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_ELITE_MONTHLY_PRICE_ID=price_...
STRIPE_ELITE_ANNUAL_PRICE_ID=price_...

# Public price IDs used by the pricing page (safe to expose to browser)
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_ELITE_MONTHLY_PRICE_ID=price_...

# ---------------------------------------------------------------------------
# Telegram
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=...
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=tradeclawbot

# Channel / group IDs (use negative numbers for groups, e.g. -1001234567890)
TELEGRAM_FREE_CHANNEL_ID=-100...
TELEGRAM_PRO_GROUP_ID=-100...
TELEGRAM_ELITE_GROUP_ID=-100...

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/tradeclaw

# ---------------------------------------------------------------------------
# Redis (optional — used for API rate limiting on Elite tier)
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# ---------------------------------------------------------------------------
# Market Data API Keys (all optional — free tiers, keyless fallbacks exist)
# ---------------------------------------------------------------------------
# Finnhub — US stock quotes, 60 req/min free → https://finnhub.io/
FINNHUB_API_KEY=
# Twelve Data — multi-asset OHLCV, 800 req/day free → https://twelvedata.com/
TWELVE_DATA_API_KEY=
# Financial Modeling Prep — fundamentals, 250 req/day free → https://financialmodelingprep.com/
FMP_API_KEY=
# FRED — US economic data, 120 req/min free → https://fred.stlouisfed.org/
FRED_API_KEY=
# CryptoCompare — deep crypto history, 100k calls/month free → https://min-api.cryptocompare.com/
CRYPTOCOMPARE_API_KEY=
# OANDA — forex & metals OHLCV, free practice account → https://developer.oanda.com/
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=
# Set to "live" for real trading account (default: practice)
# OANDA_API_ENV=live
